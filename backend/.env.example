# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aws_updates

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# AWS Bedrock (LLM simplification)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Amazon Translate
TRANSLATE_REGION=us-east-1

# RSS Feed
AWS_RSS_FEED_URL=https://aws.amazon.com/about-aws/whats-new/recent/feed/

# Pipeline schedule (cron expression, default: every 6 hours)
# Override for local dev: "*/5 * * * *" = every 5 minutes
PIPELINE_CRON=0 */6 * * *

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
